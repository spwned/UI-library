🎨 Theme Properties (Set BEFORE creating windows)
Library.MainColor = Color3.fromRGB(28, 28, 28)       -- Panel background
Library.BackgroundColor = Color3.fromRGB(20, 20, 20) -- Groupbox background
Library.AccentColor = Color3.fromRGB(0, 85, 255)     -- Highlights/buttons
Library.OutlineColor = Color3.fromRGB(50, 50, 50)    -- Borders
Library.FontColor = Color3.fromRGB(255, 255, 255)    -- Text
Library.Font = Enum.Font.Code                        -- UI Font
🪟 Window & Tab API
local Window = Library:CreateWindow({
    Title = "Menu Title",
    Center = true,              -- Spawn centered
    AutoShow = true,            -- Show on create
    Size = UDim2.fromOffset(550, 600),
    Position = UDim2.fromOffset(100, 100), -- If not centered
})

local Tab = Window:AddTab("Tab Name")  -- Returns tab object
Tab Organization Methods
Tab:AddLeftGroupbox("Name")    -- Left column container
Tab:AddRightGroupbox("Name")   -- Right column container
Tab:AddLeftTabbox("Name")      -- Nested tabs (left)
Tab:AddRightTabbox("Name")     -- Nested tabs (right)
🎛️ UI Elements Reference
Toggle
Groupbox:AddToggle("UniqueID", {
    Text = "Display Text",
    Default = false,
    Tooltip = "Hover info",
    Risky = false,
    Callback = function(Value: boolean)
    end,
})

Methods:

.SetValue(bool)
.OnChanged(func)
.AddColorPicker()
.AddKeyPicker()
Slider
Groupbox:AddSlider("UniqueID", {
    Text = "Slider Label",
    Default = 50,
    Min = 0,
    Max = 100,
    Rounding = 0,
    Suffix = "%",
    Compact = false,
    Callback = function(Value: number)
    end,
})

Methods:

.SetValue(num)
.OnChanged(func)
Dropdown
Groupbox:AddDropdown("UniqueID", {
    Text = "Dropdown Label",
    Values = {"Option1", "Option2"},
    Default = "Option1",
    Multi = false,
    AllowNull = true,
    SpecialType = "Player", -- "Player" or "Team"
    Callback = function(Value: string|table)
    end,
})

Methods:

.SetValue(val)
.SetValues(newList)
.OnChanged(func)
ColorPicker
Groupbox:AddColorPicker("UniqueID", {
    Title = "Picker Label",
    Default = Color3.fromRGB(255, 0, 0),
    Transparency = 0,
    Callback = function(Color: Color3)
    end,
})

Methods:

.SetValueRGB(Color3)
.SetValue({H,S,V}, alpha)
.OnChanged(func)
KeyPicker
Groupbox:AddKeyPicker("UniqueID", {
    Default = "E",
    Mode = "Toggle", -- "Always", "Toggle", "Hold"
    Text = "Keybind Label",
    NoUI = false,
    SyncToggleState = false,
    Callback = function(Toggled: boolean)
    end,
    ChangedCallback = function(Key)
    end,
})

Methods:

.SetValue({Key, Mode})
.OnClick(func)
.OnChanged(func)
